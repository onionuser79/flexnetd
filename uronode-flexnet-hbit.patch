diff --git a/gateway.c b/gateway.c
index 7b2dd3b..0af1519 100644
--- a/gateway.c
+++ b/gateway.c
@@ -242,6 +242,14 @@ static ax25io *connect_to(char **addr, int family, int escape, int compr)
       close(fd);
       return NULL;
     }
+    /* For FlexNet outbound connects, our callsign is the first digi
+     * in the via-list (originating node). Mark it as already-repeated
+     * (H bit = 0x80) so downstream nodes process the next digi.
+     * Without this, the frame goes out with our digi unmarked and
+     * the neighbor ignores it (not its callsign to digi). */
+    if (family == AF_FLEXNET && sa.ax.fsa_ax25.sax25_ndigis > 0) {
+      sa.ax.fsa_digipeater[0].ax25_call[6] |= 0x80;
+    }
     strcpy(User.dl_name, strupr(addr[1]));
     strcpy(User.dl_port, strlwr(addr[0]));
     sa.ax.fsa_ax25.sax25_family = AF_AX25;
